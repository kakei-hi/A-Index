# print(yy)
for (xx in seq(xmin_outer, xmax_outer, by = dd)){
vp <- st_point(c(xx, yy))
vp <- st_sfc(vp)
st_crs(vp) <- 3035
if (in_out_judge(vp[[1]], outer) == "INSIDE" &&
in_out_judge(vp[[1]], obstruction) == "OUTSIDE"){
in_out.tbl <-
in_out.tbl %>%
add_row(
x = xx,
y = yy)
}
# else {
#   print(paste("FALSE: ", xx))
# }
}
